    "triggers": [
      {
        "id": "ink_below_threshold",
        "title": {
          "en": "Ink level drops below threshold"
        },
        "titleFormatted": {
          "en": "[[ink]] ink drops below [[threshold]]%"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=epson-et2850"
          },
          {
            "name": "ink",
            "type": "dropdown",
            "title": {
              "en": "Ink colour"
            },
            "values": [
              {
                "id": "ink_level_black",
                "label": {
                  "en": "Black"
                }
              },
              {
                "id": "ink_level_cyan",
                "label": {
                  "en": "Cyan"
                }
              },
              {
                "id": "ink_level_magenta",
                "label": {
                  "en": "Magenta"
                }
              },
              {
                "id": "ink_level_yellow",
                "label": {
                  "en": "Yellow"
                }
              }
            ]
          },
          {
            "name": "threshold",
            "type": "number",
            "title": {
              "en": "Threshold (%)"
            },
            "min": 1,
            "max": 99,
            "step": 1,
            "placeholder": {
              "en": "20"
            }
          }
        ],
        "tokens": [
          {
            "name": "level",
            "type": "number",
            "title": {
              "en": "Ink level (%)"
            },
            "example": 15
          }
        ]
      },
      {
        "id": "printer_state_changed",
        "title": {
          "en": "Printer state changed"
        },
        "titleFormatted": {
          "en": "Printer state changed to [[state]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=epson-et2850"
          },
          {
            "name": "state",
            "type": "dropdown",
            "title": {
              "en": "New state"
            },
            "values": [
              {
                "id": "any",
                "label": {
                  "en": "Any"
                }
              },
              {
                "id": "idle",
                "label": {
                  "en": "Idle"
                }
              },
              {
                "id": "processing",
                "label": {
                  "en": "Printing"
                }
              },
              {
                "id": "stopped",
                "label": {
                  "en": "Stopped"
                }
              }
            ]
          }
        ],
        "tokens": [
          {
            "name": "state",
            "type": "string",
            "title": {
              "en": "New state"
            },
            "example": "idle"
          }
        ]
      }
    ],
