{
  "id": "com.homestyle.epson-et2850",
  "version": "1.7.0",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "name": { "en": "Epson ET-2850 Printer" },
  "description": { "en": "Print images from a URL on your Epson ET-2850 via Wi-Fi" },
  "category": ["tools"],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png"
  },
  "author": {
    "name": "Magnus Thune Holm",
    "email": "magnus.thune.holm@gmail.com"
  },
  "settings": [],
  "api": {
    "getInkLevels": {
      "method": "GET",
      "path": "/ink_levels"
    }
  },
  "discovery": {
    "epson_et2850": {
      "type": "mdns-sd",
      "mdns-sd": {
        "name": "epson_et2850",
        "protocol": "tcp",
        "type": "_ipp"
      }
    }
  }
}
