{
  "id": "printer_state_changed",
  "title": { "en": "Printer state changed" },
  "titleFormatted": { "en": "Printer state changed to [[state]]" },
  "args": [
    {
      "name": "device",
      "type": "device",
      "filter": "driver_id=epson-et2850"
    },
    {
      "name": "state",
      "type": "dropdown",
      "title": { "en": "New state" },
      "values": [
        { "id": "any",        "label": { "en": "Any"      } },
        { "id": "idle",       "label": { "en": "Idle"     } },
        { "id": "processing", "label": { "en": "Printing" } },
        { "id": "stopped",    "label": { "en": "Stopped"  } }
      ]
    }
  ],
  "tokens": [
    {
      "name": "state",
      "type": "string",
      "title": { "en": "New state" },
      "example": "idle"
    }
  ]
}
