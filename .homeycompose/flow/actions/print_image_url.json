{
  "id": "print_image_url",
  "title": {
    "en": "Print image from URL"
  },
  "titleFormatted": {
    "en": "Print image from [[image_url]] on [[printer_ip]] ([[copies]] copies)"
  },
  "hint": {
    "en": "Fetches an image from a URL and sends it to your Epson ET-2850 for printing."
  },
  "args": [
    {
      "name": "printer_ip",
      "type": "text",
      "label": {
        "en": "Printer IP address"
      },
      "placeholder": {
        "en": "e.g. 192.168.1.42"
      }
    },
    {
      "name": "image_url",
      "type": "text",
      "label": {
        "en": "Image URL"
      },
      "placeholder": {
        "en": "https://example.com/image.jpg"
      }
    },
    {
      "name": "copies",
      "type": "number",
      "label": {
        "en": "Number of copies"
      },
      "placeholder": {
        "en": "1"
      },
      "min": 1,
      "max": 20,
      "step": 1
    }
  ]
}